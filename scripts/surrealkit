#!/usr/bin/env python3
"""Secret-safe SurrealKit wrapper and authentication baseline gate."""

from __future__ import annotations

import base64
import hashlib
import json
import os
from pathlib import Path
import re
import subprocess
import sys
import tempfile
import urllib.error
import urllib.request
import uuid

PINNED_VERSION = "0.7.0"
AUTH_TABLES = ("auth_session", "login_throttle", "user")
STORED_ATTACHMENT_ROLLOUT = "20260721104500__stored_attachment_schema"
MANDATORY_INTERVENTION_ROLLOUT = (
    "20260721133849__mandatory_intervention_scheduling_snapshots"
)
ROOT = Path(__file__).resolve().parent.parent
EXPECTED_CATALOG = ROOT / "database/tests/fixtures/authentication_catalog.json"
DEFAULT_REPORT = ROOT / "artifacts/migration-report.json"
ROLLOUT_ID_PATTERN = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_-]*$")
ENVIRONMENT_PATTERN = re.compile(r"^[a-z0-9][a-z0-9_-]*$")


class SafeFailure(Exception):
    """An operational failure whose message contains no configured values."""


def required_environment() -> dict[str, str]:
    names = (
        "SURREALDB_ENDPOINT",
        "SURREALDB_ROOT_USERNAME",
        "SURREALDB_ROOT_PASSWORD",
        "SURREALDB_NAMESPACE",
        "SURREALDB_DATABASE",
    )
    values: dict[str, str] = {}
    missing: list[str] = []
    for name in names:
        value = os.environ.get(name, "").strip()
        if value:
            values[name] = value
        else:
            missing.append(name)
    if missing:
        raise SafeFailure(f"incomplete SurrealKit configuration: missing {', '.join(missing)}")
    return values


def mapped_environment(values: dict[str, str]) -> dict[str, str]:
    endpoint = values["SURREALDB_ENDPOINT"]
    if endpoint.startswith("ws://"):
        endpoint = "http://" + endpoint.removeprefix("ws://")
    elif endpoint.startswith("wss://"):
        endpoint = "https://" + endpoint.removeprefix("wss://")
    elif not endpoint.startswith(("http://", "https://")):
        raise SafeFailure("SURREALDB_ENDPOINT is unsupported by SurrealKit")

    environment = os.environ.copy()
    environment.update(
        {
            "SURREALDB_HOST": endpoint,
            "SURREALDB_USER": values["SURREALDB_ROOT_USERNAME"],
            "SURREALDB_PASSWORD": values["SURREALDB_ROOT_PASSWORD"],
            "SURREALDB_NAME": values["SURREALDB_DATABASE"],
            "SURREALDB_AUTH_LEVEL": "root",
            "SURREALDB_FOLDER": str(ROOT / "database"),
        }
    )
    return environment


def verify_cli() -> None:
    try:
        result = subprocess.run(
            ["surrealkit", "--version"],
            check=False,
            capture_output=True,
            text=True,
        )
    except FileNotFoundError as error:
        raise SafeFailure("SurrealKit is required; install pinned version 0.7.0") from error
    if result.returncode != 0:
        raise SafeFailure("SurrealKit version check failed")
    words = result.stdout.strip().split()
    if PINNED_VERSION not in words:
        raise SafeFailure(f"unsupported SurrealKit version; expected {PINNED_VERSION}")


def query(environment: dict[str, str], sql: str) -> list[object]:
    credentials = (
        f"{environment['SURREALDB_USER']}:{environment['SURREALDB_PASSWORD']}".encode()
    )
    request = urllib.request.Request(
        environment["SURREALDB_HOST"].rstrip("/") + "/sql",
        data=sql.encode(),
        headers={
            "Accept": "application/json",
            "Authorization": "Basic " + base64.b64encode(credentials).decode(),
            "Content-Type": "text/plain",
            "Surreal-DB": environment["SURREALDB_NAME"],
            "Surreal-NS": environment["SURREALDB_NAMESPACE"],
        },
    )
    try:
        with urllib.request.urlopen(request, timeout=10) as response:
            payload = json.load(response)
    except (OSError, urllib.error.HTTPError, json.JSONDecodeError) as error:
        raise SafeFailure("SurrealDB catalog query failed") from error

    results: list[object] = []
    for statement in payload:
        if statement.get("status") != "OK":
            raise SafeFailure("SurrealDB catalog query failed")
        results.append(statement.get("result"))
    return results


def live_catalog(
    environment: dict[str, str], allow_metadata: bool, allow_business: bool = False
) -> dict[str, object]:
    statements = ["INFO FOR DB"] + [f"INFO FOR TABLE {table}" for table in AUTH_TABLES]
    database_info, *table_info = query(environment, ";".join(statements) + ";")
    expected_names = set(AUTH_TABLES)
    if allow_metadata:
        expected_names.update(("__entity", "__rollout"))
    live_names = set(database_info["tables"])
    valid_names = (
        expected_names.issubset(live_names)
        if allow_business
        else live_names == expected_names
    )
    if not valid_names:
        raise SafeFailure("catalog drift detected during database table comparison")

    return {
        table: {
            "table": database_info["tables"][table],
            "fields": info["fields"],
            "indexes": info["indexes"],
        }
        for table, info in zip(AUTH_TABLES, table_info, strict=True)
    }


def record_fingerprint(environment: dict[str, str]) -> str:
    statements = [f"SELECT * FROM {table} ORDER BY id" for table in AUTH_TABLES]
    records = query(environment, ";".join(statements) + ";")
    logical = json.dumps(records, sort_keys=True, separators=(",", ":"), ensure_ascii=False)
    return hashlib.sha256(logical.encode()).hexdigest()


def verify_catalog(
    environment: dict[str, str], allow_metadata: bool, allow_business: bool = False
) -> None:
    expected = json.loads(EXPECTED_CATALOG.read_text())
    actual = live_catalog(environment, allow_metadata, allow_business)
    if actual != expected:
        for table in AUTH_TABLES:
            if actual.get(table) != expected.get(table):
                raise SafeFailure(f"catalog drift detected for authentication table {table}")
        raise SafeFailure("authentication catalog drift detected")


def run_cli(arguments: list[str], environment: dict[str, str]) -> int:
    return subprocess.run(["surrealkit", *arguments], env=environment, check=False).returncode


def report_path(arguments: list[str]) -> tuple[list[str], Path]:
    cleaned: list[str] = []
    requested: Path | None = None
    iterator = iter(arguments)
    for argument in iterator:
        if argument == "--json-out":
            try:
                requested = Path(next(iterator))
            except StopIteration as error:
                raise SafeFailure("--json-out requires a report path") from error
        elif argument.startswith("--json-out="):
            requested = Path(argument.partition("=")[2])
        else:
            cleaned.append(argument)
    configured = os.environ.get("PIPAUTO_MIGRATION_REPORT", "").strip()
    return cleaned, requested or (Path(configured) if configured else DEFAULT_REPORT)


def sanitize_report(raw_path: Path, destination: Path, result: int) -> None:
    destination.parent.mkdir(parents=True, exist_ok=True)
    report: dict[str, object] = {
        "schema_version": 1,
        "status": "passed" if result == 0 else "failed",
        "phase": "surrealkit_test",
    }
    try:
        raw = json.loads(raw_path.read_text())
    except (OSError, json.JSONDecodeError):
        raw = {}

    for field in (
        "started_at",
        "finished_at",
        "duration_ms",
        "suites_total",
        "suites_failed",
        "cases_total",
        "cases_passed",
        "cases_failed",
    ):
        if field in raw:
            report[field] = raw[field]
    report["suites"] = [
        {
            "suite_file": suite.get("suite_file"),
            "suite_name": suite.get("suite_name"),
            "cases": [
                {
                    "name": case.get("name"),
                    "kind": case.get("kind"),
                    "passed": case.get("passed"),
                }
                for case in suite.get("cases", [])
            ],
        }
        for suite in raw.get("suites", [])
    ]
    destination.write_text(json.dumps(report, indent=2, sort_keys=True) + "\n")


def run_tests(arguments: list[str], environment: dict[str, str]) -> int:
    arguments, destination = report_path(arguments)
    temporary = tempfile.NamedTemporaryFile(prefix="pipauto-migration-", suffix=".json", delete=False)
    raw_path = Path(temporary.name)
    temporary.close()
    try:
        result = run_cli([*arguments, "--json-out", str(raw_path)], environment)
        sanitize_report(raw_path, destination, result)
        return result
    finally:
        raw_path.unlink(missing_ok=True)


def rollout_id(value: str) -> str:
    if not ROLLOUT_ID_PATTERN.fullmatch(value):
        raise SafeFailure("rollout id contains unsupported characters")
    return value


def clear_rollout_lock(environment: dict[str, str]) -> None:
    query(
        environment,
        "DELETE __entity WHERE ns = 'pipauto_rollout_gate' AND key = 'global';",
    )


def run_rollout_start(arguments: list[str], environment: dict[str, str]) -> int:
    if len(arguments) != 3:
        raise SafeFailure("rollout start requires exactly one rollout id")
    selected = rollout_id(arguments[2])
    if run_cli(["rollout", "status", selected], environment) != 0:
        raise SafeFailure(f"rollout {selected} preflight failed")
    rows = query(
        environment,
        f"SELECT status FROM __rollout WHERE record::id(id) = '{selected}' LIMIT 1;",
    )[0]
    status = rows[0].get("status") if rows else None
    if status is None:
        verify_catalog(environment, allow_metadata=True, allow_business=True)
    if selected == MANDATORY_INTERVENTION_ROLLOUT:
        result = query(
            environment,
            "RETURN count(SELECT * FROM intervention);",
        )[0]
        if not isinstance(result, int) or result < 0:
            raise SafeFailure("intervention rollout preflight count could not be verified")
        if result != 0:
            raise SafeFailure(
                "mandatory intervention scheduling requires an empty intervention table; "
                "reset and reseed only an explicitly disposable development/test database, "
                "otherwise stop and request an approved preservation plan"
            )
    owner = uuid.uuid4().hex
    query(
        environment,
        "CREATE ONLY __entity CONTENT { "
        "ns: 'pipauto_rollout_gate', key: 'global', "
        f"val: {{ owner: '{owner}' }}, updated_at: time::now() }};",
    )
    try:
        return run_cli(arguments, environment)
    finally:
        query(
            environment,
            "DELETE __entity WHERE ns = 'pipauto_rollout_gate' "
            f"AND key = 'global' AND val.owner = '{owner}';",
        )


def run_rollout_complete(arguments: list[str], environment: dict[str, str]) -> int:
    if len(arguments) != 3:
        raise SafeFailure("rollout complete requires exactly one rollout id")
    selected = rollout_id(arguments[2])
    if selected == STORED_ATTACHMENT_ROLLOUT:
        result = query(
            environment,
            "RETURN count(SELECT * FROM attachment "
            "WHERE storage_state = 'metadata_only');",
        )[0]
        if not isinstance(result, int) or result < 0:
            raise SafeFailure("metadata-only attachment count could not be verified")
        print(f"metadata_only attachments before contract deletion: {result}", flush=True)
    return run_cli(arguments, environment)


def deployment_gate(arguments: list[str], environment: dict[str, str]) -> int:
    if len(arguments) != 3:
        raise SafeFailure("deployment-gate requires an environment and rollout id")
    selected_environment = arguments[1].strip().lower()
    if not ENVIRONMENT_PATTERN.fullmatch(selected_environment):
        raise SafeFailure("deployment environment contains unsupported characters")
    selected_rollout = rollout_id(arguments[2])
    rows = query(
        environment,
        f"SELECT status FROM __rollout WHERE record::id(id) = '{selected_rollout}' LIMIT 1;",
    )[0]
    status = rows[0].get("status") if rows else "planned"
    if status == "ready_to_complete":
        print(
            f"DEPLOYMENT PERMITTED: {selected_environment} rollout "
            f"{selected_rollout} is ready_to_complete."
        )
        return 0
    actions = {
        "planned": "run the reviewed rollout start phase",
        "running_start": "follow the interrupted-rollout repair procedure",
        "running_complete": "follow the interrupted-rollout repair procedure",
        "running_rollback": "follow the interrupted-rollout repair procedure",
        "failed": "make a reviewed retry-or-rollback decision",
        "completed": "use a new forward rollout or isolated backup recovery",
        "rolled_back": "do not deploy code that requires this rollout",
    }
    action = actions.get(status, "preserve evidence and escalate the unknown rollout state")
    print(
        f"DEPLOYMENT BLOCKED: {selected_environment} rollout {selected_rollout} "
        f"is {status}. Action: {action}.",
        file=sys.stderr,
    )
    return 1


def baseline_authentication(environment: dict[str, str]) -> int:
    verify_catalog(environment, allow_metadata=False)
    before = record_fingerprint(environment)
    result = run_cli(["rollout", "baseline"], environment)
    if result != 0:
        raise SafeFailure("SurrealKit authentication baseline failed")
    verify_catalog(environment, allow_metadata=True)
    after = record_fingerprint(environment)
    if before != after:
        raise SafeFailure("authentication records changed during baseline")
    print("authentication catalog and records verified; baseline captured")
    return 0


def main() -> int:
    verify_cli()
    values = required_environment()
    environment = mapped_environment(values)
    arguments = sys.argv[1:]
    if arguments == ["baseline-authentication"]:
        return baseline_authentication(environment)
    if not arguments:
        raise SafeFailure("a SurrealKit command is required")
    if arguments[0] == "test":
        return run_tests(arguments, environment)
    if arguments[0] == "deployment-gate":
        return deployment_gate(arguments, environment)
    if arguments[:2] == ["rollout", "start"]:
        return run_rollout_start(arguments, environment)
    if arguments[:2] == ["rollout", "complete"]:
        return run_rollout_complete(arguments, environment)
    if arguments[:2] in (["rollout", "repair"], ["rollout", "rollback"]):
        result = run_cli(arguments, environment)
        if result == 0:
            clear_rollout_lock(environment)
        return result
    return run_cli(arguments, environment)


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except SafeFailure as error:
        print(f"error: {error}", file=sys.stderr)
        raise SystemExit(1) from None
