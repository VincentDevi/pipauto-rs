#!/usr/bin/env bash
set -euo pipefail

readonly ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly CI_COMPOSE_PROJECT_NAME="pipauto-vin38-ci"
readonly CI_COMPOSE_FILE="$ROOT/compose.ci.yaml"

if docker compose version >/dev/null 2>&1; then
  COMPOSE=(docker compose)
else
  COMPOSE=(docker-compose)
fi

export SURREALDB_ENDPOINT="ws://localhost:18000"
export SURREALDB_ROOT_USERNAME="root"
export SURREALDB_ROOT_PASSWORD="local-ci-only"
export SURREALDB_NAMESPACE="pipauto_ci"
export SURREALDB_DATABASE="pipauto_ci"
export PIPAUTO_JWT_SECRET="AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
export PIPAUTO_CSRF_SECRET="AQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQE="
export PIPAUTO_CANONICAL_ORIGIN="http://localhost:5150"
export PIPAUTO_SESSION_LIFETIME_SECONDS="43200"
export PIPAUTO_MIGRATION_REPORT="$ROOT/artifacts/migration-report.json"

case "$SURREALDB_DATABASE" in
  pipauto_development|*production*|*prod*)
    echo "error: CI refuses development or production database names" >&2
    exit 1
    ;;
esac

cleanup() {
  "${COMPOSE[@]}" --project-name "$CI_COMPOSE_PROJECT_NAME" --file "$CI_COMPOSE_FILE" \
    down --volumes --remove-orphans >/dev/null 2>&1 || true
}

on_exit() {
  local status=$?
  trap - EXIT
  cleanup
  exit "$status"
}
trap on_exit EXIT

cd "$ROOT"
cargo fmt --check
cargo check
cargo clippy --all-targets --all-features -- -D warnings

"${COMPOSE[@]}" --project-name "$CI_COMPOSE_PROJECT_NAME" --file "$CI_COMPOSE_FILE" \
  up --detach --wait

COMPOSE_PROJECT_NAME="$CI_COMPOSE_PROJECT_NAME" COMPOSE_FILE="$CI_COMPOSE_FILE" \
  ./scripts/attachment-volume-smoke

./scripts/surrealkit test --parallel 2

latest_rollout="$(find database/rollouts -maxdepth 1 -type f -name '*.toml' -print | sort | tail -n 1)"
if [ -z "$latest_rollout" ]; then
  echo "error: no committed rollout manifest found" >&2
  exit 1
fi
./scripts/surrealkit rollout lint "$latest_rollout"

if rg -n 'local-ci-only|SURREALDB_ROOT_PASSWORD|password_hash|jti_digest|identifier_digest' \
  "$PIPAUTO_MIGRATION_REPORT"; then
  echo "error: migration report contains credentials or row-shaped authentication data" >&2
  exit 1
fi

if rg -n \
  'BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY|eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}|\$argon2(id|i|d)\$v=' \
  README.md docs database/tests database/snapshots src tests; then
  echo "error: tracked documentation, fixtures, snapshots, errors, or tests contain secret-shaped data" >&2
  exit 1
fi

cargo test migration
cargo test
cargo loco routes
cargo loco task
