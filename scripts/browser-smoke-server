#!/bin/sh
set -eu

project="pipauto-browser-smoke"
compose_file="compose.browser.yaml"

if docker compose version >/dev/null 2>&1; then
  compose() { docker compose "$@"; }
else
  compose() { docker-compose "$@"; }
fi

cleanup() {
  compose --project-name "$project" --file "$compose_file" down --volumes >/dev/null 2>&1 || true
}
trap cleanup EXIT HUP INT TERM

cleanup
compose --project-name "$project" --file "$compose_file" up --detach --wait surrealdb >/dev/null

response=$(curl --fail --silent --show-error --user root:browser-smoke-only \
  --header 'accept: application/json' \
  --data 'DEFINE NAMESPACE IF NOT EXISTS pipauto_browser; USE NS pipauto_browser; DEFINE DATABASE IF NOT EXISTS browser_smoke;' \
  http://127.0.0.1:18000/sql)
case "$response" in
  *'"status":"ERR"'*)
    printf '%s\n' 'Browser database initialization failed.' >&2
    exit 1
    ;;
esac

export SURREALDB_ROOT_USERNAME="root"
export SURREALDB_ROOT_PASSWORD="browser-smoke-only"
export SURREALDB_ENDPOINT="ws://127.0.0.1:18000"
export SURREALDB_NAMESPACE="pipauto_browser"
export SURREALDB_DATABASE="browser_smoke"

./scripts/surrealkit sync
./scripts/surrealkit sync --dry-run

compose --project-name "$project" --file "$compose_file" exec -T surrealdb \
  /surreal sql --endpoint http://localhost:8000 --username root \
  --password browser-smoke-only --namespace pipauto_browser --database browser_smoke \
  --hide-welcome --multi >/dev/null <<'SQL'
CREATE user:browser_smoke CONTENT {
  email: 'browser-smoke@example.invalid',
  email_normalized: 'browser-smoke@example.invalid',
  display_name: 'Browser Smoke',
  password_hash: crypto::argon2::generate('Browser smoke password 123!'),
  active: true
};
SQL

PIPAUTO_JWT_SECRET=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA= \
PIPAUTO_CSRF_SECRET=AQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQE= \
PIPAUTO_CANONICAL_ORIGIN=http://localhost:5150 \
PIPAUTO_SESSION_LIFETIME_SECONDS=43200 \
cargo loco start
