# Local SurrealDB server and application connection settings.
SURREALDB_ROOT_USERNAME=root
SURREALDB_ROOT_PASSWORD=root
SURREALDB_ENDPOINT=ws://localhost:8000
SURREALDB_NAMESPACE=pipauto
SURREALDB_DATABASE=pipauto_development
SURREALDB_TEST_DATABASE=pipauto_test

# Generate each secret independently: openssl rand -base64 32
PIPAUTO_JWT_SECRET=
PIPAUTO_CSRF_SECRET=
PIPAUTO_CANONICAL_ORIGIN=http://localhost:5150
# Optional; defaults to 12 hours and accepts 300 through 86400 seconds.
PIPAUTO_SESSION_LIFETIME_SECONDS=43200

# Workshop scheduling uses Europe/Brussels in config/development.yaml. Test configuration uses the
# same IANA timezone so local-time behavior never depends on the host timezone.
